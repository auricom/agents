{
  "name": "prpilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "NODE_ENV=development tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:logging": "node scripts/check-logging-policy.mjs",
    "check": "npm run check:logging && npm run build && npm run test"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.55.4",
    "express": "^4.21.2",
    "prom-client": "^15.1.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
